# ===============================
# SERVER
# ===============================
NODE_ENV=development
PORT=4000

# ===============================
# DATABASE
# ===============================
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require

# ===============================
# AUTH
# ===============================
JWT_SECRET=replace-with-a-long-random-secret
JWT_SECRET_FALLBACKS=
JWT_EXPIRES_IN=7d
SSN_HASH_SECRET=replace-with-a-separate-random-secret
DEFAULT_USER_EMAIL=guest@example.com

# Optional Stack Auth values
JWKS_URL=
STACK_PROJECT_ID=
STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# ===============================
# FRONTEND + CORS
# ===============================
APP_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:4000
ALLOW_ANY_ORIGIN=0

# ===============================
# EMAIL
# ===============================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=2525
SMTP_USER=apikey
SMTP_PASS=replace-with-smtp-password
MAIL_FROM=noreply@example.com
MAIL_REPLY_TO=support@example.com
SUPPORT_EMAIL=support@example.com

# ===============================
# BRANDING
# ===============================
BRAND_NAME=Base Credit
BRAND_PRIMARY=#0b74de
BRAND_SECONDARY=#0a66c2
CTA_COLOR=#0b74de
BRAND_LOGO_PATH=assets/logo.png
BRAND_LOGO_URL=http://localhost:4000/assets/logo.png

# ===============================
# ADMIN
# ===============================
ADMIN_USER=admin@example.com
ADMIN_PASS=replace-with-strong-admin-password

# ===============================
# FILES / UPLOADS
# ===============================
UPLOAD_DIR=uploads

# ===============================
# NOTIFICATIONS / LOGGING
# ===============================
BANKSWIFT_NOTIFY_EMAIL=ops@example.com
BANKSWIFT_NOTIFY_WEBHOOK=
GS_LOG_ENDPOINT=
GS_LOG_SECRET=
SHEETS_SECRET=
